# =============================================================================
# Agent Executor 环境变量
# 复制此文件为 .env 并填入实际值
# .env 已在 .gitignore 中，不会上传到 git
# =============================================================================

# --- Anthropic API（默认，Claude Code SDK 使用）---
ANTHROPIC_API_KEY=sk-ant-xxx

# --- Git HTTPS 认证（用于 auto_push / feature push）---
GH_TOKEN=ghp_xxx

# --- 第三方模型 API（按需配置，agent YAML 中通过变量引用）---
# MiniMax
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic

# GLM (智谱)
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/anthropic

# Kimi (月之暗面)
# KIMI_API_KEY=
# KIMI_BASE_URL=https://api.moonshot.cn/v1
